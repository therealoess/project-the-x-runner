{
  "name": "project-the-x-runner",
  "productName": "Project THE X Runner",
  "version": "1.0.10",
  "description": "Branded desktop runner for Project THE X. Connects your dashboard to the local Claude CLI on your computer so AI work runs on your own subscription.",
  "main": "main.js",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "homepage": "https://project-the-x.com",
  "author": {
    "name": "Project THE X",
    "email": "support@project-the-x.com",
    "url": "https://project-the-x.com"
  },
  "scripts": {
    "start": "electron .",
    "build:mac":   "electron-builder --mac   --publish never",
    "build:win":   "electron-builder --win   --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all":   "electron-builder -mwl    --publish never"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.projectthex.runner",
    "productName": "Project THE X Runner",
    "copyright": "© 2026 Project THE X",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Project-THE-X",
        "repo": "Project-THE-X-runner"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../companion/companion.js",
        "to": "companion/companion.js"
      },
      {
        "from": "../companion/package.json",
        "to": "companion/package.json"
      },
      {
        "from": "../companion/node_modules",
        "to": "companion/node_modules"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "Project-THE-X-Runner-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Project-THE-X-Runner-win-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Project-THE-X-Runner-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "icon": "assets/icon.png",
      "title": "Install Project THE X Runner"
    }
  }
}
